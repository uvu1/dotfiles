{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.codex/auth.json)",
      "Read(~/.claude.json)"
    ]
  },
  "effortLevel": "xhigh",
  "theme": "dark",
  "agentPushNotifEnabled": true
}
